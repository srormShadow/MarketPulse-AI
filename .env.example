# Application
APP_NAME="MarketPulse AI"
APP_ENV="development"
DEBUG=false
API_V1_PREFIX="/api/v1"

# Database — SQLite (default local dev)
DATABASE_URL="sqlite:///./marketpulse.db"

# DynamoDB — set USE_DYNAMO=true to switch backend
USE_DYNAMO=false
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""
DYNAMO_ENDPOINT_URL=""  # e.g. http://localhost:8000 for DynamoDB Local

# S3
S3_ENDPOINT_URL=""      # e.g. http://localhost:4566 for LocalStack
S3_DATA_BUCKET="marketpulse-data"
S3_MODEL_BUCKET="marketpulse-models"

# Bedrock
MOCK_BEDROCK=false
BEDROCK_MODEL_ID="anthropic.claude-3-5-sonnet-20241022-v2:0"
# Use inference profile ID/ARN in production when on-demand model invocation is not supported.
BEDROCK_INFERENCE_PROFILE_ID=""

# CORS — comma-separated production frontend origins (dev origins excluded in production)
FRONTEND_URL=""

# Security
API_KEY=""                 # Set a strong key to protect all endpoints; empty = open (dev only)
ENVIRONMENT="development"  # Set to "production" to disable debug routes, Swagger, and dev CORS origins
UPLOAD_MAX_SIZE_MB=10      # Maximum CSV upload size in MB

# Logging
LOG_LEVEL="INFO"
LOG_FORMAT="%(asctime)s | %(levelname)s | %(name)s | %(message)s"
