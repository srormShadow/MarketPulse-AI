{
  "family": "marketpulse-ai-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::850995558029:role/marketpulse-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::850995558029:role/marketpulse-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "marketpulse-ai",
      "image": "850995558029.dkr.ecr.ap-south-1.amazonaws.com/marketpulse-ai:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "USE_DYNAMO", "value": "true" },
        { "name": "AWS_REGION", "value": "ap-south-1" },
        { "name": "MOCK_BEDROCK", "value": "false" },
        { "name": "S3_DATA_BUCKET", "value": "marketpulse-data-uploads" },
        { "name": "S3_MODELS_BUCKET", "value": "marketpulse-model-artifacts" },
        { "name": "ENVIRONMENT", "value": "production" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8000/health')\" || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/marketpulse-ai",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
