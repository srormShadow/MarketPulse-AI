# MarketPulse AI production environment template

USE_DYNAMO=true
MOCK_BEDROCK=false

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=<your_aws_access_key_id>
AWS_SECRET_ACCESS_KEY=<your_aws_secret_access_key>
AWS_SESSION_TOKEN=<optional_session_token>

DYNAMO_ENDPOINT_URL=
S3_ENDPOINT_URL=
BEDROCK_ENDPOINT_URL=

S3_DATA_BUCKET=<your_prod_data_bucket>
S3_MODEL_BUCKET=<your_prod_model_bucket>

# Optional app settings
APP_ENV=production
DEBUG=false
